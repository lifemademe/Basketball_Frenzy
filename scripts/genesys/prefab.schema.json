{
    "$schema": "https://json-schema.org/draft-07/schema",
    "$id": "genesys.js.prefab.schema.json",
    "type": "object",
    "properties": {
        "$version": {
            "type": "integer"
        },
        "class": {
            "$ref": "class_string"
        },
        "ctor": {
            "$ref": "actor_ctor"
        },
        "properties": {
            "$ref": "actor_properties"
        }
    },
    "definitions": {
        "actor_ctor": {
            "type": "object",
            "properties": {
                "rootComponent": {
                    "$ref": "component"
                }
            }
        },
        "actor_properties": {
            "type": "object"
        },
        "component_ctor": {
            "type": "object"
        },
        "component_properties": {
            "type": "object",
            "properties": {
                "position": {
                    "$ref": "type_vector3"
                },
                "rotation": {
                    "$ref": "type_euler"
                },
                "scale": {
                    "$ref": "type_euler"
                }
            }
        },
        "type_vector3": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "examples": [[0, 0, 0, "v"]]
        },
        "type_euler": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "examples": [[0, 0, 0, "e"]]
        },
        "component": {
            "type": "object",
            "properties": {
                "class": {
                    "$ref": "class_string"
                },
                "ctor": {
                    "$ref": "component_ctor"
                },
                "properties": {
                    "$ref": "component_properties"
                },
                "children": {
                    "type": "array",
                    "items": {
                        "$ref": "component"
                    }
                }
            }
        },
        "class_string": {
            "type": "string",
            "pattern": "(GAME|ENGINE)\\..*"
        }
    }
}