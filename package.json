{
  "scripts": {
    "build": "pnpm run generate-property-metadata && tsc && pnpm exec tsx ./scripts/genesys/write-build-stamp.ts",
    "turbo:build": "turbo run build",
    "generate-property-metadata": "pnpm exec tsx node_modules/@gnsx/genesys.js/scripts/generate-property-metadata.ts src/game-data.ts",
    "build-project": "pnpm exec tsx ./scripts/genesys/build-project.ts",
    "preinstall": "node -e \"try{require('child_process').execSync('pnpm remove @gnsx/genesys.harness',{stdio:'pipe'})}catch(e){}\"",
    "postinstall": "pnpm exec tsx ./scripts/genesys/post-install.ts",
    "lint": "eslint . --fix --ext .ts,.tsx",
    "remove-engine-comments": "pnpm exec tsx ./scripts/genesys/remove-engine-comments.ts",
    "dev": "pnpm exec tsx ./scripts/genesys/dev/generate-manifest.ts && vite",
    "validate-prefabs": "pnpm exec tsx ./scripts/genesys/validate-prefabs.ts",
    "check-pack-isolation": "pnpm exec tsx ./scripts/genesys/check-pack-isolation.ts",
    "export-pack": "pnpm exec tsx ./scripts/genesys/export-pack.ts",
    "install-developer-skills": "pnpm exec tsx ./scripts/genesys/install-developer-skills.ts"
  },
  "packageManager": "pnpm@10.25.0",
  "type": "module",
  "dependencies": {
    "three": "npm:@gnsx/three@0.184.20",
    "@gnsx/genesys.js": "12.3.6-staging"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/three": "npm:@gnsx/three-types@0.184.11",
    "@typescript-eslint/parser": "8.59.2",
    "@typescript-eslint/utils": "8.59.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "adm-zip": "0.5.17",
    "ajv": "8.20.0",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "tsx": "4.22.4",
    "turbo": "2.9.14",
    "typescript": "5.9.3",
    "vite": "8.0.12",
    "vite-plugin-mkcert": "2.0.0",
    "vite-plugin-node-polyfills": "0.26.0",
    "@types/adm-zip": "0.5.8"
  },
  "name": "Basketball_frenzy",
  "version": "0.0.1"
}